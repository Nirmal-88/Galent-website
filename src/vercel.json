{
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "insights.galent.com" }],
      "destination": "/knowledge-hub.html",
      "permanent": false
    },
    {
      "source": "/index.html",
      "has": [{ "type": "host", "value": "insights.galent.com" }],
      "destination": "/knowledge-hub.html",
      "permanent": false
    }
  ]
}
